# Anthropic API key — required for all LLM calls (generation, ranking, screening)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token — from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# Your Telegram chat ID — send a message to your bot, then visit:
# https://api.telegram.org/bot<token>/getUpdates and find "chat":{"id":...}
TELEGRAM_CHAT_ID=987654321

# Set to true once your LinkedIn session is established in user_data/
# Leave as false (or unset) for first-time login — Playwright will open a visible browser
LINKEDIN_HEADLESS=false

# Your LinkedIn profile URL — used to find your most recent post for first-comment posting
# Format: https://www.linkedin.com/in/your-username/
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/your-username/

# NewsData.io API key — optional, supplements RSS feeds with broader news coverage
# Sign up free at https://newsdata.io/register
NEWSDATA_API_KEY=
